{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "superadmin",
        "admin",
        "user"
      ],
      "default": "user"
    },
    "town_id": {
      "type": "string",
      "description": "Foreign key to TownConfig. Set by superadmin to assign user to a municipality."
    }
  }
}